# Optional live-model path. Deterministic mode works without these values.
MODEL_API_KEY=
MODEL_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4.1-mini
MODEL_TEMPERATURE=0.1
MODEL_TIMEOUT_SECONDS=12

NEXT_PUBLIC_API_URL=http://localhost:8000

# Persistent local demo-principal key. The API creates a random Ed25519 key on
# first use. Keep this file in the data volume and never commit its contents.
MANDATEMESH_KEY_PATH=

# Policy decision point (Level 1 protected mode). Under Docker Compose the API
# reaches OPA in-network at http://opa:8181; running the API on the host, point
# it at your local OPA (see README) — default http://localhost:8181.
OPA_URL=http://localhost:8181

# Fail-closed policy request timeout. Keep this short enough for a live demo.
OPA_TIMEOUT_SECONDS=5
